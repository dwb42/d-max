{
  "gateway": {
    "mode": "local"
  },
  "agents": {
    "defaults": {
      "workspace": "/app/openclaw/workspace",
      "model": {
        "primary": "openai-codex/gpt-5.5"
      },
      "models": {
        "openai-codex/gpt-5.5": {}
      }
    }
  },
  "channels": {
    "telegram": {
      "enabled": true,
      "botToken": "${TELEGRAM_BOT_TOKEN}",
      "dmPolicy": "pairing",
      "groups": {
        "*": {
          "requireMention": true
        }
      }
    }
  },
  "messages": {
    "tts": {
      "auto": "inbound",
      "provider": "gemini",
      "providers": {
        "gemini": {
          "apiKey": "${GEMINI_API_KEY}",
          "model": "gemini-3.1-flash-tts-preview"
        }
      }
    }
  },
  "mcp": {
    "servers": {
      "d-max": {
        "command": "npm",
        "args": ["run", "mcp"]
      }
    }
  },
  "auth": {
    "profiles": {
      "openai-codex:default": {
        "provider": "openai-codex",
        "mode": "oauth"
      }
    },
    "order": {
      "openai-codex": ["openai-codex:default"]
    }
  },
  "plugins": {
    "entries": {
      "openai": {
        "enabled": true
      }
    }
  }
}
