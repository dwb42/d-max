{
  "gateway": {
    "mode": "local",
    "auth": {
      "mode": "none"
    }
  },
  "agents": {
    "defaults": {
      "workspace": "/app/openclaw/workspace",
      "model": {
        "primary": "openai/gpt-5.5"
      },
      "models": {
        "openai/gpt-5.5": {
          "agentRuntime": {
            "id": "codex"
          }
        }
      }
    },
    "list": [
      {
        "id": "main",
        "name": "DMAX Default Agent",
        "default": true,
        "workspace": "/app/openclaw/workspace",
        "tools": {
          "allow": [
            "d-max__listCategories",
            "d-max__createCategory",
            "d-max__updateCategory",
            "d-max__listInitiatives",
            "d-max__getInitiative",
            "d-max__createInitiative",
            "d-max__updateInitiative",
            "d-max__archiveInitiative",
            "d-max__updateInitiativeMarkdown",
            "d-max__listInitiativeRelations",
            "d-max__createInitiativeRelation",
            "d-max__deleteInitiativeRelation",
            "d-max__getInitiativeGraph",
            "d-max__getInitiativeMindmap",
            "d-max__summarizeInitiativeMindmap",
            "d-max__draftMindmapChanges",
            "d-max__commitMindmapChangeDraft",
            "d-max__createMindmapFreestyleNode",
            "d-max__updateMindmapFreestyleNode",
            "d-max__deleteMindmapFreestyleNode",
            "d-max__listTasks",
            "d-max__createTask",
            "d-max__updateTask",
            "d-max__completeTask",
            "d-max__deleteTask",
            "d-max__listTaskChecklistItems",
            "d-max__createTaskChecklistItem",
            "d-max__updateTaskChecklistItem",
            "d-max__deleteTaskChecklistItem",
            "d-max__reorderTaskChecklistItems",
            "d-max__listPartyTimelineEntries",
            "d-max__createPartyTimelineEntry",
            "d-max__updatePartyTimelineEntry",
            "d-max__deletePartyTimelineEntry",
            "d-max__listMediaAttachments",
            "d-max__attachMediaToEntity",
            "d-max__updateMediaAttachment",
            "d-max__deleteMediaAttachment",
            "d-max__reorderMediaAttachments",
            "d-max__listPeople",
            "d-max__getPerson",
            "d-max__createPerson",
            "d-max__updatePerson",
            "d-max__listOrganizations",
            "d-max__getOrganization",
            "d-max__createOrganization",
            "d-max__updateOrganization",
            "d-max__listRelationshipTypes",
            "d-max__listPartyRelationships",
            "d-max__createPartyRelationship",
            "d-max__deletePartyRelationship",
            "d-max__listParticipantRoleTypes",
            "d-max__listEntityParticipants",
            "d-max__createEntityParticipant",
            "d-max__deleteEntityParticipant",
            "d-max__listPartyContactPoints",
            "d-max__createPartyContactPoint",
            "d-max__updatePartyContactPoint",
            "agents_list",
            "sessions_list",
            "sessions_spawn",
            "sessions_send",
            "sessions_yield",
            "session_status",
            "subagents"
          ]
        },
        "subagents": {
          "allowAgents": ["dmax-research", "dmax-google-workspace"],
          "requireAgentId": true
        }
      },
      {
        "id": "dmax-research",
        "name": "DMAX Research Agent",
        "workspace": "/app/openclaw/workspace/dmax-research",
        "tools": {
          "allow": [
            "group:web",
            "d-max__listCategories",
            "d-max__listInitiatives",
            "d-max__getInitiative",
            "d-max__listInitiativeRelations",
            "d-max__getInitiativeGraph",
            "d-max__listTasks"
          ],
          "deny": [
            "group:runtime",
            "group:fs",
            "group:media",
            "group:automation",
            "group:sessions",
            "browser",
            "canvas",
            "gateway",
            "media",
            "memory",
            "sandbox",
            "tts"
          ]
        },
        "subagents": {
          "allowAgents": [],
          "requireAgentId": true
        }
      },
      {
        "id": "dmax-google-workspace",
        "name": "DMAX Google Workspace Agent",
        "workspace": "/app/openclaw/workspace/dmax-google-workspace",
        "tools": {
          "allow": [
            "group:runtime"
          ],
          "deny": [
            "group:web",
            "group:fs",
            "group:media",
            "group:automation",
            "group:sessions",
            "browser",
            "canvas",
            "gateway",
            "media",
            "memory",
            "sandbox",
            "tts"
          ]
        },
        "subagents": {
          "allowAgents": [],
          "requireAgentId": true
        }
      }
    ]
  },
  "auth": {
    "profiles": {
      "openai-codex:default": {
        "provider": "openai-codex",
        "mode": "oauth"
      }
    },
    "order": {
      "openai-codex": ["openai-codex:default"]
    }
  },
  "channels": {
    "telegram": {
      "enabled": false
    }
  },
  "plugins": {
    "bundledDiscovery": "allowlist",
    "allow": ["openai", "codex", "dmax-dynamic-tools"],
    "load": {
      "paths": [
        "/app/data/openclaw-state/npm/node_modules/@openclaw/codex",
        "/app/openclaw/plugins/dmax-dynamic-tools"
      ]
    },
    "slots": {
      "memory": "none"
    },
    "entries": {
      "openai": {
        "enabled": true
      },
      "codex": {
        "enabled": true,
        "config": {
          "codexPlugins": {
            "enabled": false
          },
          "appServer": {
            "approvalPolicy": "never",
            "sandbox": "read-only"
          }
        }
      },
      "dmax-dynamic-tools": {
        "enabled": true
      }
    }
  }
}
