{
  "gateway": {
    "mode": "local",
    "auth": {
      "mode": "none"
    }
  },
  "agents": {
    "defaults": {
      "workspace": "/Users/dw/Projects/d-max/openclaw/workspace",
      "model": {
        "primary": "openai-codex/gpt-5.5"
      },
      "models": {
        "openai-codex/gpt-5.5": {}
      }
    },
    "list": [
      {
        "id": "main",
        "name": "d-max Default Agent",
        "default": true,
        "workspace": "/Users/dw/Projects/d-max/openclaw/workspace",
        "tools": {
          "allow": [
            "d-max__listCategories",
            "d-max__createCategory",
            "d-max__updateCategory",
            "d-max__listInitiatives",
            "d-max__getInitiative",
            "d-max__createInitiative",
            "d-max__updateInitiative",
            "d-max__archiveInitiative",
            "d-max__updateInitiativeMarkdown",
            "d-max__listInitiativeRelations",
            "d-max__createInitiativeRelation",
            "d-max__deleteInitiativeRelation",
            "d-max__getInitiativeGraph",
            "d-max__getInitiativeMindmap",
            "d-max__createMindmapFreestyleNode",
            "d-max__updateMindmapFreestyleNode",
            "d-max__deleteMindmapFreestyleNode",
            "d-max__listTasks",
            "d-max__createTask",
            "d-max__updateTask",
            "d-max__completeTask",
            "d-max__deleteTask",
            "d-max__listTaskChecklistItems",
            "d-max__createTaskChecklistItem",
            "d-max__updateTaskChecklistItem",
            "d-max__deleteTaskChecklistItem",
            "d-max__reorderTaskChecklistItems",
            "d-max__listMediaAttachments",
            "d-max__attachMediaToEntity",
            "d-max__updateMediaAttachment",
            "d-max__deleteMediaAttachment",
            "d-max__reorderMediaAttachments",
            "d-max__listPeople",
            "d-max__getPerson",
            "d-max__createPerson",
            "d-max__updatePerson",
            "d-max__listOrganizations",
            "d-max__getOrganization",
            "d-max__createOrganization",
            "d-max__updateOrganization",
            "d-max__listRelationshipTypes",
            "d-max__listPartyRelationships",
            "d-max__createPartyRelationship",
            "d-max__deletePartyRelationship",
            "d-max__listParticipantRoleTypes",
            "d-max__listEntityParticipants",
            "d-max__createEntityParticipant",
            "d-max__deleteEntityParticipant",
            "d-max__listPartyContactPoints",
            "d-max__createPartyContactPoint",
            "d-max__updatePartyContactPoint",
            "agents_list",
            "sessions_list",
            "sessions_spawn",
            "sessions_send",
            "sessions_yield",
            "session_status",
            "subagents"
          ]
        },
        "subagents": {
          "allowAgents": ["dmax-research", "dmax-google-workspace"],
          "requireAgentId": true
        }
      },
      {
        "id": "dmax-research",
        "name": "d-max Research Agent",
        "workspace": "/Users/dw/Projects/d-max/openclaw/workspace/dmax-research",
        "tools": {
          "allow": [
            "group:web",
            "d-max__listCategories",
            "d-max__listInitiatives",
            "d-max__getInitiative",
            "d-max__listInitiativeRelations",
            "d-max__getInitiativeGraph",
            "d-max__listTasks"
          ],
          "deny": [
            "group:runtime",
            "group:fs",
            "group:media",
            "group:automation",
            "group:sessions",
            "browser",
            "gateway",
            "cron"
          ]
        },
        "subagents": {
          "allowAgents": [],
          "requireAgentId": true
        }
      },
      {
        "id": "dmax-google-workspace",
        "name": "d-max Google Workspace Agent",
        "workspace": "/Users/dw/Projects/d-max/openclaw/workspace/dmax-google-workspace",
        "tools": {
          "allow": [
            "group:runtime"
          ],
          "deny": [
            "group:web",
            "group:fs",
            "group:media",
            "group:automation",
            "group:sessions",
            "browser",
            "canvas",
            "gateway",
            "media",
            "memory",
            "sandbox",
            "tts"
          ]
        },
        "subagents": {
          "allowAgents": [],
          "requireAgentId": true
        }
      }
    ]
  },
  "models": {
    "providers": {
      "openai-codex": {
        "baseUrl": "https://chatgpt.com/backend-api",
        "api": "openai-codex-responses",
        "auth": "oauth",
        "models": [
          {
            "id": "gpt-5.5",
            "name": "GPT-5.5",
            "api": "openai-codex-responses",
            "reasoning": true,
            "input": ["text", "image"],
            "cost": {
              "input": 0,
              "output": 0,
              "cacheRead": 0,
              "cacheWrite": 0
            },
            "contextWindow": 400000,
            "maxTokens": 128000
          }
        ]
      }
    }
  },
  "mcp": {
    "servers": {
      "d-max": {
        "command": "npm",
        "args": ["run", "mcp"]
      }
    }
  },
  "auth": {
    "profiles": {
      "openai-codex:default": {
        "provider": "openai-codex",
        "mode": "oauth"
      }
    },
    "order": {
      "openai-codex": ["openai-codex:default"]
    }
  },
  "channels": {
    "telegram": {
      "enabled": false
    }
  },
  "plugins": {
    "entries": {
      "openai": {
        "enabled": true
      }
    }
  }
}
