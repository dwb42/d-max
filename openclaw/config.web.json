{
  "gateway": {
    "mode": "local",
    "auth": {
      "mode": "none"
    }
  },
  "agents": {
    "defaults": {
      "workspace": "/Users/dw/Projects/d-max/openclaw/workspace",
      "model": {
        "primary": "openai-codex/gpt-5.5"
      },
      "models": {
        "openai-codex/gpt-5.5": {}
      }
    },
    "list": [
      {
        "id": "main",
        "name": "d-max Default Agent",
        "default": true,
        "workspace": "/Users/dw/Projects/d-max/openclaw/workspace",
        "tools": {
          "allow": [
            "d-max__listCategories",
            "d-max__createCategory",
            "d-max__updateCategory",
            "d-max__listProjects",
            "d-max__getProject",
            "d-max__createProject",
            "d-max__updateProject",
            "d-max__archiveProject",
            "d-max__updateProjectMarkdown",
            "d-max__listTasks",
            "d-max__createTask",
            "d-max__updateTask",
            "d-max__completeTask",
            "d-max__deleteTask"
          ]
        },
        "subagents": {
          "allowAgents": ["dmax-research"],
          "requireAgentId": true
        }
      },
      {
        "id": "dmax-research",
        "name": "d-max Research Agent",
        "workspace": "/Users/dw/Projects/d-max/openclaw/workspace/dmax-research",
        "tools": {
          "allow": [
            "group:web",
            "d-max__listCategories",
            "d-max__listProjects",
            "d-max__getProject",
            "d-max__listTasks"
          ],
          "deny": [
            "group:runtime",
            "group:fs",
            "group:media",
            "group:automation",
            "group:sessions",
            "browser",
            "gateway",
            "cron"
          ]
        },
        "subagents": {
          "allowAgents": [],
          "requireAgentId": true
        }
      }
    ]
  },
  "models": {
    "providers": {
      "openai-codex": {
        "baseUrl": "https://chatgpt.com/backend-api",
        "api": "openai-codex-responses",
        "auth": "oauth",
        "models": [
          {
            "id": "gpt-5.5",
            "name": "GPT-5.5",
            "api": "openai-codex-responses",
            "reasoning": true,
            "input": ["text", "image"],
            "cost": {
              "input": 0,
              "output": 0,
              "cacheRead": 0,
              "cacheWrite": 0
            },
            "contextWindow": 400000,
            "maxTokens": 128000
          }
        ]
      }
    }
  },
  "mcp": {
    "servers": {
      "d-max": {
        "command": "npm",
        "args": ["run", "mcp"]
      }
    }
  },
  "auth": {
    "profiles": {
      "openai-codex:default": {
        "provider": "openai-codex",
        "mode": "oauth"
      }
    },
    "order": {
      "openai-codex": ["openai-codex:default"]
    }
  },
  "channels": {
    "telegram": {
      "enabled": false
    }
  },
  "plugins": {
    "entries": {
      "openai": {
        "enabled": true
      }
    }
  }
}
