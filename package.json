{
  "name": "d-max",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Agentic project and task memory system for Dietrich.",
  "scripts": {
    "dev": "tsx src/main.ts",
    "dev:app": "npm run dev",
    "dev:raw": "concurrently \"npm run api\" \"npm run web\" \"npm run voice:agent -- --watch\"",
    "api": "tsx src/api/server.ts",
    "web": "vite --host 0.0.0.0",
    "web:build": "vite build",
    "mcp": "tsx src/mcp/server.ts",
    "smoke:mcp": "tsx scripts/mcp-smoke.ts",
    "diagnostics:chat-turn": "tsx scripts/analyze-chat-turn.ts",
    "voice:capability:xai": "tsx scripts/xai-realtime-capability.ts",
    "voice:agent": "tsx src/voice/livekit-agent.ts",
    "voice:server": "tsx src/voice/server.ts",
    "start:container": "sh scripts/start-container.sh",
    "setup": "tsx scripts/setup-db.ts",
    "test": "vitest run --config vitest.config.ts",
    "test:watch": "vitest --config vitest.config.ts",
    "typecheck": "tsc --noEmit",
    "build": "tsc"
  },
  "dependencies": {
    "@livekit/components-react": "^2.9.20",
    "@livekit/components-styles": "^1.2.0",
    "@livekit/rtc-node": "^0.13.27",
    "@modelcontextprotocol/sdk": "^1.17.5",
    "better-sqlite3": "^11.10.0",
    "dotenv": "^16.4.7",
    "livekit-client": "^2.18.7",
    "livekit-server-sdk": "^2.15.2",
    "lucide-react": "^1.12.0",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "ws": "^8.20.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.13.10",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^5.1.2",
    "concurrently": "^9.2.1",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2",
    "vite": "^7.3.2",
    "vitest": "^3.0.8"
  },
  "engines": {
    "node": ">=22.14"
  }
}
