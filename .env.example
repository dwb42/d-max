# DMAX
NODE_ENV=development
DATABASE_PATH=./data/dmax.dev.sqlite
TZ=Europe/Berlin
DMAX_API_PORT=3088
DMAX_WEB_BASE_URL=http://localhost:5173
DMAX_WEB_DIST_DIR=./dist-web
DMAX_HOST_PORT=49415
DMAX_MEDIA_STORAGE_DIR=./data/media
DMAX_MEDIA_MAX_UPLOAD_BYTES=52428800
DMAX_OPENCLAW_CONFIG_PATH=./openclaw/config.local.json
DMAX_OPENCLAW_STATE_DIR=./data/openclaw-web-state
DMAX_OPENCLAW_CLIENT_STATE_DIR=
DMAX_OPENCLAW_MODEL=openai/gpt-5.5
DMAX_OPENCLAW_GATEWAY_URL=
DMAX_OPENCLAW_SESSION_ID=dmax-web-app-chat
DMAX_OPENCLAW_TIMEOUT_SECONDS=240
# Required by production docker-compose.yml. Generate strong values locally or
# in the VPS secrets environment; do not commit real values.
DMAX_INTERNAL_TOOL_TOKEN=
OPENCLAW_GATEWAY_TOKEN=

# OpenClaw / Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_USER_IDS=

# Voice providers
OPENAI_API_KEY=
OPENAI_TRANSCRIBE_MODEL=gpt-4o-mini-transcribe
OPENAI_MEDIA_ANALYSIS_MODEL=gpt-4.1-mini
OPENAI_TTS_MODEL=gpt-4o-mini-tts
OPENAI_TTS_VOICE=alloy
GEMINI_API_KEY=

# Google Calendar OAuth
# In production, DMAX_WEB_BASE_URL and GOOGLE_OAUTH_REDIRECT_URI must use the public domain.
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:3088/api/config/google-calendar/oauth/callback
GOOGLE_CALENDAR_TOKEN_PATH=./data/google-calendar-oauth.json

# Future realtime voice
XAI_API_KEY=
XAI_REALTIME_MODEL=grok-voice-think-fast-1.0
DMAX_VOICE_ALLOWED_CALLERS=
DMAX_VOICE_PUBLIC_BASE_URL=
DMAX_VOICE_PORT=3099
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_VOICE_NUMBER=

# LiveKit WebRTC
LIVEKIT_URL=
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
