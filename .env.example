# d-max
NODE_ENV=development
DATABASE_PATH=./data/dmax.dev.sqlite
TZ=Europe/Berlin
DMAX_API_PORT=3088
DMAX_OPENCLAW_CONFIG_PATH=./openclaw/config.local.json
DMAX_OPENCLAW_STATE_DIR=./data/openclaw-web-state
DMAX_OPENCLAW_MODEL=openai-codex/gpt-5.5
DMAX_OPENCLAW_SESSION_ID=dmax-web-app-chat
DMAX_OPENCLAW_TIMEOUT_SECONDS=240

# OpenClaw / Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_USER_IDS=

# Voice providers
OPENAI_API_KEY=
OPENAI_TRANSCRIBE_MODEL=gpt-4o-mini-transcribe
GEMINI_API_KEY=

# Future realtime voice
XAI_API_KEY=
XAI_REALTIME_MODEL=grok-voice-think-fast-1.0
DMAX_VOICE_ALLOWED_CALLERS=
DMAX_VOICE_PUBLIC_BASE_URL=
DMAX_VOICE_PORT=3099
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_VOICE_NUMBER=

# LiveKit WebRTC
LIVEKIT_URL=
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
